# Metrics collector config — TEMPLATE. Copy to a private file (e.g. /etc/metrics/metrics.env,
# mode 0600) and fill in. The PVE API token is a SECRET (read-only, but still a credential).
#
# Create the token on the Proxmox host with a read-only role:
#   pveum user add metrics@pve
#   pveum acl modify / -user metrics@pve -role PVEAuditor
#   pveum user token add metrics@pve collector --privsep 0
# (the last command prints the token secret once — copy it into PVE_TOKEN_SECRET below)

PVE_API_URL=https://pve.example:8006      # your Proxmox API endpoint
PVE_NODE=pve                              # the node name (see `pvesh get /nodes`)
PVE_TOKEN_ID=metrics@pve!collector
PVE_TOKEN_SECRET=
METRICS_DB=~/.local/share/metrics/metrics.db
METRICS_SITE=~/metrics-site/site
METRICS_DAYS=90
